# Variáveis de ambiente necessárias
# Copie este arquivo para .env e preencha os valores

# Banco de dados (SQLite)
DATABASE_URL=file:./db/custom.db

# VAPID Keys para notificações push
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu-email@example.com

# URL do serviço WhatsApp (Render: https://pos-operatorio-whatsapp.onrender.com)
WHATSAPP_SERVICE_URL=http://localhost:3040
